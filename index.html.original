<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Parchilo — AI-Powered Invoice Platform</title>
  <link rel="icon" type="image/x-icon" href="favicon.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
  <style>
    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    :root {
      --white: #ffffff;
      --bg: #f4f5f7;
      --border: #e2e8f0;
      --border-dark: #2d3748;
      --black: #0a0a0a;
      --blue: #2563eb;
      --blue-lt: #eff6ff;
      --lime: #c8f135;
      --lime-dark: #a8d020;
      --green: #10b981;
      --green-lt: #ecfdf5;
      --amber: #f59e0b;
      --amber-lt: #fef3c7;
      --muted: #4a5568;
      --dim: #718096;
      --xdim: #a0aec0;
      --shadow-sm: 0 1px 3px rgba(10, 10, 10, .05);
      --shadow: 0 4px 16px rgba(10, 10, 10, .06);
      --shadow-md: 0 8px 24px rgba(10, 10, 10, .08);
      --shadow-lg: 0 20px 48px rgba(10, 10, 10, .1);
      --shadow-nav: 0 2px 20px rgba(10, 10, 10, .08);
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      background: var(--bg);
      color: var(--black);
      font-family: 'Inter', sans-serif;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    /* ═══════ NAV ═══════ */
    .nav-wrap {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 900;
      padding: 8px 4vw;
      pointer-events: none;
    }

    nav {
      max-width: 500px;
      margin: 0 auto;
      height: 46px;
      background: rgba(255, 255, 255, 0.85);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-radius: 100px;
      border: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 6px 0 16px;
      box-shadow: var(--shadow-nav);
      pointer-events: all;
      transition: all .3s ease;
    }

    nav.scrolled {
      background: rgba(255, 255, 255, 0.95);
      box-shadow: 0 4px 30px rgba(10, 10, 10, .12);
    }

    .nav-logo {
      display: flex;
      align-items: center;
      text-decoration: none;
      flex-shrink: 0;
    }

    .logo-wordmark {
      font-size: 16.5px;
      font-weight: 900;
      color: var(--black);
      letter-spacing: -.04em;
      text-transform: uppercase;
      display: flex;
      align-items: center;
    }

    .logo-invert {
      background: var(--black);
      color: var(--white);
      padding: 1px 4px;
      border-radius: 4px;
      margin: 0 1px;
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 2px;
      list-style: none;
      background: rgba(0, 0, 0, 0.04);
      border-radius: 100px;
      padding: 3px;
    }

    .nav-links li a {
      display: flex;
      align-items: center;
      gap: 6px;
      text-decoration: none;
      font-size: 12.5px;
      font-weight: 600;
      color: var(--muted);
      padding: 5px 12px;
      border-radius: 100px;
      transition: all .15s;
      white-space: nowrap;
    }

    .nav-links li a:hover,
    .nav-links li a.active {
      background: var(--white);
      color: var(--black);
      box-shadow: var(--shadow-sm);
    }

    .nav-cta {
      display: flex;
      align-items: center;
      gap: 6px;
    }

    /* Hamburger */
    .nav-hamburger {
      display: none;
      flex-direction: column;
      gap: 5px;
      background: none;
      border: none;
      cursor: pointer;
      padding: 8px;
      flex-shrink: 0;
    }

    .nav-hamburger span {
      display: block;
      width: 20px;
      height: 2px;
      background: var(--black);
      border-radius: 2px;
      transition: all .25s;
    }

    .nav-hamburger.open span:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }

    .nav-hamburger.open span:nth-child(2) {
      opacity: 0;
    }

    .nav-hamburger.open span:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
    }

    /* Mobile menu */
    .mobile-menu {
      display: none;
      position: fixed;
      top: 66px;
      left: 4vw;
      right: 4vw;
      z-index: 800;
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 16px;
      box-shadow: var(--shadow-lg);
      flex-direction: column;
      gap: 4px;
    }

    .mobile-menu.open {
      display: flex;
    }

    .mobile-menu a {
      display: flex;
      align-items: center;
      gap: 10px;
      text-decoration: none;
      font-size: 15px;
      font-weight: 600;
      color: var(--muted);
      padding: 12px 14px;
      border-radius: 12px;
      transition: all .15s;
    }

    .mobile-menu a:hover {
      background: var(--bg);
      color: var(--black);
    }

    .mobile-menu-cta {
      margin-top: 8px;
      padding-top: 12px;
      border-top: 1px solid var(--border);
    }

    /* ═══════ HERO ═══════ */
    .hero {
      min-height: 100vh;
      padding: 120px 4vw 70px;
      background: var(--white);
      border-bottom: 1px solid var(--border);
      position: relative;
      overflow: hidden;
      display: flex;
      align-items: center;
    }

    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image: radial-gradient(circle, #c8d4e0 1px, transparent 1px);
      background-size: 28px 28px;
      opacity: .35;
      pointer-events: none;
    }

    .hero-accent {
      position: absolute;
      top: 0;
      right: 0;
      width: 320px;
      height: 320px;
      background: var(--lime);
      clip-path: polygon(100% 0, 0 0, 100% 100%);
      pointer-events: none;
      opacity: .4;
    }

    .hero-inner {
      max-width: 1340px;
      width: 100%;
      margin: 0 auto;
      display: grid;
      /* Grid columns: Left-side Card (0.95fr) and Right-side text copy (1.05fr) matching layout instruction */
      grid-template-columns: 0.95fr 1.05fr;
      gap: 64px;
      align-items: center;
      position: relative;
      z-index: 2;
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 5px 14px 5px 8px;
      background: var(--lime);
      border-radius: 100px;
      font-size: 12px;
      font-weight: 700;
      color: var(--black);
      margin-bottom: 24px;
      animation: fadeUp .6s ease both;
    }

    .badge-dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: var(--black);
      animation: blink 1.8s infinite;
    }

    @keyframes blink {
      0%, 100% { opacity: 1 }
      50% { opacity: .3 }
    }

    h1.hero-h {
      font-size: clamp(30px, 3.8vw, 50px);
      font-weight: 900;
      line-height: 1.15;
      letter-spacing: -.03em;
      color: var(--black);
      margin-bottom: 20px;
      animation: fadeUp .6s .1s ease both;
    }

    h1.hero-h .line-block {
      display: inline-block;
      background: var(--black);
      color: var(--white);
      padding: 2px 12px;
      border-radius: 6px;
    }

    .hero-p {
      font-size: 16px;
      color: var(--muted);
      line-height: 1.7;
      max-width: 520px;
      margin-bottom: 32px;
      animation: fadeUp .6s .2s ease both;
    }

    /* Benefits checkmark list */
    .hero-features {
      list-style: none;
      margin-bottom: 24px;
      animation: fadeUp .6s .3s ease both;
    }

    .hero-features li {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 14.5px;
      color: var(--muted);
      margin-bottom: 10px;
      font-weight: 500;
    }

    .hero-features li i {
      color: var(--green);
      flex-shrink: 0;
    }

    /* ═══════ HERO CARD (THE DARK CARD) ═══════ */
    .hero-card {
      background: #0f172a;
      border: 1px solid #1e293b;
      border-radius: 20px;
      overflow: hidden;
      box-shadow: var(--shadow-lg);
      color: var(--white);
      animation: fadeUp .8s .2s ease both;
      display: flex;
      flex-direction: column;
      min-height: 480px;
      width: 100%;
    }

    .card-tabs {
      display: grid;
      grid-template-columns: 1fr 1fr;
      border-bottom: 1px solid #1e293b;
      background: #090d16;
    }

    .card-tab {
      background: none;
      border: none;
      color: var(--dim);
      font-size: 13.5px;
      font-weight: 700;
      padding: 16px;
      cursor: pointer;
      transition: all .15s;
      outline: none;
      font-family: 'Inter', sans-serif;
      text-align: center;
    }

    .card-tab:hover {
      color: var(--white);
    }

    .card-tab.active {
      color: var(--black);
      background: var(--lime);
    }

    .card-content {
      padding: 24px;
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .tab-panel {
      display: none;
      height: 100%;
    }

    .tab-panel.active {
      display: block;
    }

    /* File drop zone */
    .drop-zone {
      border: 2px dashed #334155;
      border-radius: 12px;
      padding: 44px 20px;
      text-align: center;
      cursor: pointer;
      transition: all .2s;
      background: #1e293b;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 12px;
    }

    .drop-zone:hover, .drop-zone.dragover {
      border-color: var(--lime);
      background: #243249;
    }

    .dz-icon-wrap {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      background: #0f172a;
      display: grid;
      place-items: center;
      color: var(--lime);
      box-shadow: var(--shadow-sm);
    }

    .dz-title {
      font-size: 14.5px;
      font-weight: 700;
      color: var(--white);
    }

    .dz-desc {
      font-size: 12px;
      color: var(--dim);
    }

    .dz-subtext {
      font-size: 11px;
      color: #475569;
      margin-top: 10px;
    }

    /* Simulation status loader */
    .parsing-loader {
      display: none;
      flex-direction: column;
      gap: 16px;
    }

    .loader-title {
      font-size: 15px;
      font-weight: 700;
      color: var(--lime);
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .spinner {
      width: 16px;
      height: 16px;
      border: 2px solid rgba(200, 241, 53, 0.2);
      border-top-color: var(--lime);
      border-radius: 50%;
      animation: spin 1s linear infinite;
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    .parsing-steps {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .parsing-step {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 12.5px;
      color: var(--dim);
    }

    .parsing-step.active {
      color: var(--white);
    }

    .parsing-step.done {
      color: var(--green);
    }

    .parsing-step i {
      width: 14px;
      height: 14px;
    }

    /* Manual Form Styles */
    .manual-form {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
    }

    .form-group {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .form-group label {
      font-size: 11px;
      font-weight: 700;
      color: var(--xdim);
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .form-group input, .form-group select {
      background: #1e293b;
      border: 1px solid #334155;
      color: var(--white);
      padding: 8px 12px;
      border-radius: 8px;
      font-size: 13px;
      font-family: 'Inter', sans-serif;
      outline: none;
      transition: border-color 0.15s;
    }

    .form-group input:focus, .form-group select:focus {
      border-color: var(--lime);
    }

    .items-table-wrap {
      border: 1px solid #334155;
      border-radius: 8px;
      overflow: hidden;
      margin-top: 6px;
    }

    .items-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 12px;
    }

    .items-table th {
      background: #090d16;
      color: var(--dim);
      font-weight: 700;
      text-align: left;
      padding: 6px 8px;
      border-bottom: 1px solid #334155;
    }

    .items-table td {
      padding: 6px 8px;
      background: #141b2d;
      border-bottom: 1px solid #1e293b;
    }

    .items-table input {
      width: 100%;
      background: transparent;
      border: none;
      color: var(--white);
      font-size: 12px;
      outline: none;
    }

    .items-table .num-input {
      text-align: right;
    }

    .btn-add-item {
      background: #1e293b;
      border: 1px solid #334155;
      color: var(--white);
      padding: 6px 12px;
      border-radius: 6px;
      font-size: 11px;
      font-weight: 600;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      gap: 4px;
      margin-top: 6px;
      width: fit-content;
      transition: all 0.15s;
    }

    .btn-add-item:hover {
      background: #2d3748;
      color: var(--lime);
    }

    .btn-trash {
      background: none;
      border: none;
      color: #ef4444;
      cursor: pointer;
      display: grid;
      place-items: center;
    }

    .form-totals {
      display: flex;
      justify-content: flex-end;
      gap: 16px;
      margin-top: 8px;
      font-size: 12.5px;
      font-weight: 700;
    }

    .form-totals span {
      color: var(--xdim);
    }

    .form-totals strong {
      color: var(--lime);
    }

    .btn-submit-invoice {
      width: 100%;
      background: var(--lime);
      color: var(--black);
      border: none;
      padding: 10px;
      border-radius: 8px;
      font-size: 13.5px;
      font-weight: 800;
      cursor: pointer;
      margin-top: 10px;
      font-family: 'Inter', sans-serif;
      transition: background 0.15s;
    }

    .btn-submit-invoice:hover {
      background: var(--lime-dark);
    }

    /* ═══════ INVOICES LEDGER SECTION ═══════ */
    .ledger-sect {
      padding: 80px 4vw;
      background: var(--bg);
      border-top: 1px solid var(--border);
    }

    .ledger-inner {
      max-width: 1340px;
      margin: 0 auto;
    }

    .section-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      margin-bottom: 28px;
      flex-wrap: wrap;
      gap: 16px;
    }

    .section-title {
      font-size: clamp(20px, 3vw, 32px);
      font-weight: 900;
      letter-spacing: -.03em;
    }

    .ledger-controls {
      display: flex;
      gap: 10px;
      align-items: center;
      flex-wrap: wrap;
      width: 100%;
      max-width: 600px;
    }

    .search-box {
      flex: 1;
      position: relative;
      min-width: 200px;
    }

    .search-box i {
      position: absolute;
      left: 12px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--dim);
    }

    .search-box input {
      width: 100%;
      padding: 10px 12px 10px 36px;
      border-radius: 100px;
      border: 1px solid var(--border);
      outline: none;
      font-size: 13px;
      font-family: 'Inter', sans-serif;
      transition: all 0.2s;
    }

    .search-box input:focus {
      border-color: var(--black);
      box-shadow: var(--shadow-sm);
    }

    .filter-tabs {
      display: flex;
      background: rgba(0, 0, 0, 0.05);
      padding: 3px;
      border-radius: 100px;
      list-style: none;
    }

    .filter-btn {
      background: none;
      border: none;
      font-family: 'Inter', sans-serif;
      font-size: 12px;
      font-weight: 700;
      color: var(--muted);
      padding: 7px 16px;
      border-radius: 100px;
      cursor: pointer;
      transition: all 0.15s;
    }

    .filter-btn.active {
      background: var(--white);
      color: var(--black);
      box-shadow: var(--shadow-sm);
    }

    /* Ledger Table layout */
    .ledger-card {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 16px;
      overflow: hidden;
      box-shadow: var(--shadow);
    }

    .ledger-table-wrap {
      overflow-x: auto;
    }

    .ledger-table {
      width: 100%;
      border-collapse: collapse;
      text-align: left;
      font-size: 13.5px;
    }

    .ledger-table th {
      background: #fafafa;
      padding: 14px 18px;
      font-weight: 700;
      color: var(--muted);
      border-bottom: 1px solid var(--border);
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .ledger-table td {
      padding: 16px 18px;
      border-bottom: 1px solid var(--border);
      vertical-align: middle;
    }

    .ledger-table tr:last-child td {
      border-bottom: none;
    }

    .td-client {
      font-weight: 700;
      color: var(--black);
    }

    .td-client-email {
      display: block;
      font-size: 11px;
      font-weight: 400;
      color: var(--dim);
    }

    .td-inv-num {
      font-family: 'Courier New', monospace;
      font-weight: 700;
      color: var(--muted);
    }

    .td-amount {
      font-weight: 800;
    }

    /* Status Badges */
    .status-badge {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      padding: 4px 10px;
      border-radius: 100px;
      font-size: 11px;
      font-weight: 700;
      text-transform: capitalize;
      cursor: pointer;
      transition: opacity 0.15s;
    }

    .status-badge:hover {
      opacity: 0.85;
    }

    .status-badge.paid {
      background: var(--green-lt);
      color: var(--green);
    }

    .status-badge.pending {
      background: var(--amber-lt);
      color: var(--amber);
    }

    .status-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: currentColor;
    }

    /* Action Buttons in Ledger */
    .actions-cell {
      display: flex;
      gap: 6px;
    }

    .btn-action {
      border: 1px solid var(--border);
      background: var(--white);
      color: var(--muted);
      cursor: pointer;
      padding: 6px 10px;
      border-radius: 6px;
      font-size: 12px;
      font-weight: 600;
      display: inline-flex;
      align-items: center;
      gap: 5px;
      transition: all 0.15s;
    }

    .btn-action:hover {
      border-color: var(--black);
      color: var(--black);
      background: var(--bg);
    }

    .btn-action.delete:hover {
      border-color: #f87171;
      color: #ef4444;
      background: #fef2f2;
    }

    .empty-ledger {
      padding: 48px;
      text-align: center;
      color: var(--dim);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 12px;
    }

    .empty-ledger i {
      color: var(--xdim);
    }

    /* Toast Notification */
    .toast {
      position: fixed;
      bottom: 24px;
      right: 24px;
      background: #0f172a;
      color: var(--white);
      padding: 12px 20px;
      border-radius: 10px;
      box-shadow: var(--shadow-lg);
      display: none;
      align-items: center;
      gap: 10px;
      z-index: 1100;
      font-size: 13px;
      font-weight: 600;
      border: 1px solid #1e293b;
      animation: toastSlideIn 0.3s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    }

    @keyframes toastSlideIn {
      from { transform: translateY(20px); opacity: 0; }
      to { transform: translateY(0); opacity: 1; }
    }

    .toast.show {
      display: flex;
    }

    .toast i {
      color: var(--lime);
    }

    /* ═══════ MODALS / OVERLAYS ═══════ */
    .modal-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.4);
      backdrop-filter: blur(4px);
      z-index: 1000;
      display: none;
      place-items: center;
      padding: 20px;
      overflow-y: auto;
    }

    .modal-overlay.open {
      display: grid;
    }

    .modal-container {
      background: var(--white);
      border-radius: 16px;
      max-width: 600px;
      width: 100%;
      box-shadow: var(--shadow-lg);
      border: 1px solid var(--border);
      position: relative;
      animation: modalSlideUp 0.3s cubic-bezier(0.34, 1.56, 0.64, 1) both;
      overflow: hidden;
    }

    @keyframes modalSlideUp {
      from { transform: translateY(30px); opacity: 0; }
      to { transform: translateY(0); opacity: 1; }
    }

    .modal-header {
      padding: 18px 24px;
      border-bottom: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .modal-header h3 {
      font-size: 17px;
      font-weight: 800;
      letter-spacing: -0.02em;
    }

    .modal-close {
      background: none;
      border: none;
      cursor: pointer;
      color: var(--dim);
      display: grid;
      place-items: center;
      transition: color 0.15s;
    }

    .modal-close:hover {
      color: var(--black);
    }

    .modal-body {
      padding: 24px;
      max-height: 70vh;
      overflow-y: auto;
      font-size: 13.5px;
      color: var(--muted);
    }

    .modal-body h4 {
      font-size: 14px;
      font-weight: 700;
      color: var(--black);
      margin: 16px 0 6px;
    }

    .modal-body h4:first-child {
      margin-top: 0;
    }

    .modal-body p {
      margin-bottom: 12px;
    }

    /* A4 Invoice Preview Container */
    #invoicePreviewModal .modal-container {
      max-width: 800px;
    }

    .invoice-a4-wrap {
      background: var(--bg);
      padding: 24px;
      display: flex;
      justify-content: center;
    }

    .invoice-a4 {
      background: var(--white);
      width: 100%;
      max-width: 700px;
      min-height: 800px;
      padding: 40px;
      box-shadow: var(--shadow-md);
      border: 1px solid var(--border);
      font-size: 12px;
      color: #334155;
      line-height: 1.5;
      font-family: 'Inter', sans-serif;
    }

    .a4-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      border-bottom: 2px solid var(--black);
      padding-bottom: 20px;
      margin-bottom: 24px;
    }

    .a4-logo {
      font-size: 20px;
      font-weight: 900;
      color: var(--black);
      letter-spacing: -0.04em;
    }

    .a4-logo-invert {
      background: var(--black);
      color: var(--white);
      padding: 1px 4px;
      border-radius: 3px;
      margin: 0 1px;
    }

    .a4-meta-title {
      font-size: 24px;
      font-weight: 900;
      color: var(--black);
      text-transform: uppercase;
      letter-spacing: -0.02em;
    }

    .a4-bill-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 40px;
      margin-bottom: 24px;
    }

    .a4-bill-col h5 {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      color: var(--dim);
      margin-bottom: 6px;
      letter-spacing: 0.05em;
    }

    .a4-bill-col strong {
      font-size: 13px;
      color: var(--black);
      font-weight: 700;
    }

    .a4-meta-col {
      text-align: right;
    }

    .a4-meta-grid {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 4px 12px;
      justify-content: end;
      font-size: 11.5px;
    }

    .a4-meta-grid label {
      color: var(--dim);
      font-weight: 600;
    }

    .a4-meta-grid span {
      color: var(--black);
      font-weight: 700;
      text-align: right;
    }

    .a4-table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 24px;
    }

    .a4-table th {
      background: #f8fafc;
      color: var(--muted);
      font-weight: 700;
      text-align: left;
      padding: 8px 12px;
      border-bottom: 1px solid #cbd5e1;
      font-size: 10px;
      text-transform: uppercase;
    }

    .a4-table td {
      padding: 10px 12px;
      border-bottom: 1px solid #e2e8f0;
    }

    .a4-table tr:last-child td {
      border-bottom: none;
    }

    .a4-total-grid {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 8px 24px;
      justify-content: end;
      font-size: 12px;
      max-width: 240px;
      margin-left: auto;
      margin-bottom: 32px;
    }

    .a4-total-grid label {
      color: var(--muted);
      font-weight: 500;
      text-align: right;
    }

    .a4-total-grid span {
      color: var(--black);
      font-weight: 600;
      text-align: right;
    }

    .a4-total-grid .grand-total-label {
      font-size: 14px;
      font-weight: 800;
      color: var(--black);
      border-top: 2px solid var(--black);
      padding-top: 8px;
    }

    .a4-total-grid .grand-total-val {
      font-size: 15px;
      font-weight: 900;
      color: var(--black);
      border-top: 2px solid var(--black);
      padding-top: 8px;
    }

    .a4-footer {
      border-top: 1px solid #e2e8f0;
      padding-top: 16px;
      font-size: 10.5px;
      color: var(--dim);
      text-align: center;
    }

    .modal-footer-actions {
      padding: 16px 24px;
      border-top: 1px solid var(--border);
      background: #fafafa;
      display: flex;
      justify-content: flex-end;
      gap: 10px;
    }

    .btn-modal-action {
      padding: 9px 16px;
      border-radius: 8px;
      font-size: 13px;
      font-weight: 700;
      cursor: pointer;
      font-family: 'Inter', sans-serif;
      border: 1px solid var(--border);
      background: var(--white);
      color: var(--muted);
      transition: all 0.15s;
    }

    .btn-modal-action:hover {
      border-color: var(--black);
      color: var(--black);
    }

    .btn-modal-action.primary {
      background: var(--black);
      color: var(--white);
      border-color: var(--black);
    }

    /* ═══════ FOOTER ═══════ */
    footer {
      background: var(--white);
      border-top: 1px solid var(--border);
      padding: 48px 4vw 26px;
    }

    .fg {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr;
      gap: 32px;
      max-width: 1340px;
      margin: 0 auto;
    }

    .fd {
      font-size: 12.5px;
      color: var(--dim);
      margin-top: 11px;
      line-height: 1.7;
      max-width: 280px;
    }

    .fct {
      font-size: 11.5px;
      font-weight: 700;
      color: var(--black);
      margin-bottom: 11px;
    }

    .fl {
      list-style: none;
    }

    .fl li {
      margin-bottom: 7px;
    }

    .fl a {
      text-decoration: none;
      font-size: 12.5px;
      color: var(--dim);
      transition: color .15s;
    }

    .fl a:hover {
      color: var(--black);
    }

    .fb {
      max-width: 1340px;
      margin: 36px auto 0;
      padding-top: 16px;
      border-top: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 10px;
    }

    .fbc {
      font-size: 12px;
      color: var(--dim);
    }

    .fbc span {
      color: var(--black);
      font-weight: 700;
    }

    .fbr {
      display: flex;
      gap: 5px;
      flex-wrap: wrap;
    }

    .fchip {
      font-size: 10px;
      font-weight: 600;
      color: var(--dim);
      background: var(--bg);
      border: 1px solid var(--border);
      padding: 3px 8px;
      border-radius: 100px;
    }

    /* ═══════ ANIMATIONS ═══════ */
    @keyframes fadeUp {
      from {
        opacity: 0;
        transform: translateY(20px)
      }

      to {
        opacity: 1;
        transform: translateY(0)
      }
    }

    /* ═══════ RESPONSIVE TABLET ═══════ */
    @media (max-width: 1024px) {
      .nav-links, .nav-cta {
        display: none;
      }

      .nav-hamburger {
        display: flex;
      }

      .hero-inner {
        grid-template-columns: 1fr;
        gap: 48px;
      }

      .hero-accent {
        width: 200px;
        height: 200px;
      }

      .fg {
        grid-template-columns: 1fr 1fr;
        gap: 28px;
      }

      .fd {
        max-width: 100%;
      }
    }

    /* ═══════ RESPONSIVE MOBILE ═══════ */
    @media (max-width: 640px) {
      section {
        padding: 52px 5vw;
      }

      .nav-wrap {
        padding: 10px 4vw;
      }

      nav {
        height: 50px;
        border-radius: 14px;
        padding: 0 6px 0 16px;
      }

      .mobile-menu {
        top: 70px;
        border-radius: 14px;
      }

      .hero {
        padding: 100px 5vw 48px;
        min-height: auto;
      }

      .hero-accent {
        width: 120px;
        height: 120px;
        opacity: .3;
      }

      h1.hero-h {
        font-size: clamp(28px, 8vw, 40px);
      }

      .hero-p {
        font-size: 14.5px;
        max-width: 100%;
        margin-bottom: 24px;
      }

      .ledger-controls {
        flex-direction: column;
        align-items: stretch;
      }

      .filter-tabs {
        justify-content: center;
      }

      .fg {
        grid-template-columns: 1fr;
        gap: 24px;
      }

      .fb {
        flex-direction: column;
        align-items: flex-start;
      }

      .section-header {
        align-items: stretch;
        flex-direction: column;
        gap: 12px;
      }
    }

    /* Print styles */
    @media print {
      body * {
        visibility: hidden;
      }
      .modal-overlay.open, .modal-overlay.open * {
        visibility: visible;
      }
      .modal-overlay.open {
        position: absolute;
        left: 0;
        top: 0;
        width: 100%;
        height: auto;
        background: none;
        padding: 0;
      }
      .modal-container {
        box-shadow: none;
        border: none;
        width: 100%;
        max-width: 100%;
        height: auto;
        margin: 0;
        padding: 0;
      }
      .modal-header, .modal-footer-actions, .modal-close {
        display: none !important;
      }
      .modal-body {
        padding: 0;
        max-height: none;
        overflow: visible;
      }
      .invoice-a4-wrap {
        background: none;
        padding: 0;
      }
      .invoice-a4 {
        border: none;
        box-shadow: none;
        padding: 0;
        width: 100%;
        max-width: 100%;
      }
    }
  </style>
</head>

<body>

  <!-- ══ NAV ══ -->
  <div class="nav-wrap">
    <nav id="mainNav">
      <a href="index.html" class="nav-logo">
        <span class="logo-wordmark">
          <span>PAR</span><span class="logo-invert">CHI</span><span>LO</span>
        </span>
      </a>

      <ul class="nav-links">
        <li><a href="index.html" class="active"><i data-lucide="home" style="width:13px;height:13px"></i> Home</a></li>
        <li><a href="blogs.html"><i data-lucide="book-open" style="width:13px;height:13px"></i> Blogs</a></li>
        <li><a href="contact.html"><i data-lucide="mail" style="width:13px;height:13px"></i> Contact Us</a></li>
      </ul>

      <button class="nav-hamburger" id="hamburger" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </nav>
  </div>

  <!-- Mobile menu -->
  <div class="mobile-menu" id="mobileMenu">
    <a href="index.html" class="active"><i data-lucide="home" style="width:16px;height:16px"></i> Home</a>
    <a href="blogs.html"><i data-lucide="book-open" style="width:16px;height:16px"></i> Blogs</a>
    <a href="contact.html"><i data-lucide="mail" style="width:16px;height:16px"></i> Contact Us</a>
  </div>

  <!-- ══ HERO ══ -->
  <section class="hero">
    <div class="hero-accent"></div>
    <div class="hero-inner">
      
      <!-- Hero Dark Card containing Dropzone (Swapped to Left-side Column) -->
      <div class="hero-card">
        <div class="card-content">
          <!-- Upload Panel -->
          <div class="tab-panel active" id="panelUpload">
            <div class="drop-zone" id="dropZone" style="padding: 60px 20px;">
              <div class="dz-icon-wrap">
                <i data-lucide="upload-cloud" style="width: 24px; height: 24px;"></i>
              </div>
              <div class="dz-title">Click or drag file here</div>
              <div class="dz-desc">PDF, PNG, JPEG, or WebP</div>
              <div class="dz-subtext">File items will be parsed into invoices dynamically</div>
              <input type="file" id="fileInput" style="display: none;" accept=".pdf, image/*">
            </div>

            <!-- Parsing logs (hidden by default) -->
            <div class="parsing-loader" id="parsingLoader">
              <div class="loader-title">
                <div class="spinner"></div>
                AI Parser Simulation Running...
              </div>
              <div class="parsing-steps">
                <div class="parsing-step" id="step1"><i data-lucide="loader" class="spinner"></i> <span>Reading document layout...</span></div>
                <div class="parsing-step" id="step2"><i data-lucide="circle"></i> <span>Extracting client and org fields...</span></div>
                <div class="parsing-step" id="step3"><i data-lucide="circle"></i> <span>Mapping line item tables...</span></div>
                <div class="parsing-step" id="step4"><i data-lucide="circle"></i> <span>Adding invoice to ledger database...</span></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Right Column: Titles, checklist copy, and note (Swapped to Right-side Column) -->
      <div>
        <div class="hero-badge">
          <div class="badge-dot"></div>
          No registration required
        </div>
        <h1 class="hero-h">
          Free Online<br>
          <span class="line-block">Invoice Generator</span><br>
          &amp; AI Reader.
        </h1>
        <p class="hero-p">
          Create a structured invoice instantly. Upload any purchase order to extract billing details using our client-side parser, or build invoices manually.
        </p>

        <ul class="hero-features">
          <li><i data-lucide="check-circle" style="color: var(--green); width: 18px; height: 18px;"></i> Create invoice links instantly</li>
          <li><i data-lucide="check-circle" style="color: var(--green); width: 18px; height: 18px;"></i> No account or signup needed</li>
          <li><i data-lucide="check-circle" style="color: var(--green); width: 18px; height: 18px;"></i> Clean, professional A4 print templates</li>
          <li><i data-lucide="check-circle" style="color: var(--green); width: 18px; height: 18px;"></i> PDF, PNG, JPEG, WebP supported</li>
        </ul>

        <p style="font-size: 13.5px; color: var(--muted); font-weight: 500; margin-top: 20px;">
          Perfect for freelancers, expense tracking, and instant billing.
        </p>
      </div>

    </div>
  </section>



  <!-- Toast Message -->
  <div class="toast" id="toastMessage">
    <i data-lucide="check-circle" style="width: 16px; height: 16px;"></i>
    <span id="toastText">Success!</span>
  </div>

  <!-- ══ FOOTER ══ -->
  <footer>
    <div class="fg">
      <div>
        <span class="logo-wordmark" style="font-size:16px">
          <span>PAR</span><span class="logo-invert">CHI</span><span>LO</span>
        </span>
        <p class="fd">
          An interactive single-page app for invoice management and generation, powered by Nexaura Technologies.
        </p>
      </div>
      <div>
        <div class="fct">Navigation</div>
        <ul class="fl">
          <li><a href="index.html">Home</a></li>
          <li><a href="blogs.html">Blogs</a></li>
          <li><a href="contact.html">Contact Us</a></li>
        </ul>
      </div>
      <div>
        <div class="fct">Legal Documents</div>
        <ul class="fl">
          <li><a href="terms.html">Terms &amp; Conditions</a></li>
          <li><a href="privacy.html">Privacy Policy</a></li>
        </ul>
      </div>
    </div>
    <div class="fb">
      <div class="fbc">© 2026 <span>Parchilo</span>. All rights reserved. Built by Nexaura.</div>
      <div class="fbr">
        <span class="fchip">Local DB Active</span>
        <span class="fchip">v4.5 (Dual Mode)</span>
      </div>
    </div>
  </footer>

  <!-- ═══════ MODALS ═══════ -->

  <!-- A4 Invoice Preview & Print Modal -->
  <div class="modal-overlay" id="invoicePreviewModal" onclick="closeModalOnOutsideClick(event, 'invoicePreviewModal')">
    <div class="modal-container">
      <div class="modal-header">
        <h3>Invoice Preview</h3>
        <button class="modal-close" onclick="closeModal('invoicePreviewModal')">
          <i data-lucide="x" style="width: 18px; height: 18px;"></i>
        </button>
      </div>
      <div class="modal-body" style="padding: 0;">
        <div class="invoice-a4-wrap">
          <div class="invoice-a4" id="a4Content">
            <!-- Populated dynamically via JS -->
          </div>
        </div>
      </div>
      <div class="modal-footer-actions">
        <button class="btn-modal-action" onclick="closeModal('invoicePreviewModal')">Cancel</button>
        <button class="btn-modal-action primary" onclick="printInvoice()"><i data-lucide="printer" style="width: 13px; height: 13px; display: inline-block; vertical-align: middle; margin-right: 4px;"></i>Print / Save PDF</button>
      </div>
    </div>
  </div>

  <!-- ═══════ JAVASCRIPT LOGIC ═══════ -->
  <script>
    // Initialize icons
    lucide.createIcons();

    // App state
    let invoices = [];
    let ledgerFilter = 'all';
    let currentManualItems = [];

    // Prepopulate database with mock data if empty
    const mockInvoices = [
      {
        id: "inv_1",
        invoiceNum: "INV-2026-001",
        clientName: "COMSATS University Islamabad",
        clientEmail: "info@comsats.edu.pk",
        date: "2026-07-08",
        currency: "₨",
        taxRate: 5,
        items: [
          { name: "Sony ZV-E10 Camera vlogger kit", qty: 1, price: 210000 },
          { name: "Professional heavy-duty Tripod Stand", qty: 2, price: 8500 }
        ],
        status: "paid"
      },
      {
        id: "inv_2",
        invoiceNum: "INV-2026-002",
        clientName: "Nexaura Techs Ltd",
        clientEmail: "billing@nexauratechs.com",
        date: "2026-07-07",
        currency: "$",
        taxRate: 15,
        items: [
          { name: "Enterprise API Subscription (Quarterly)", qty: 1, price: 600 },
          { name: "Technical Consulting Hours", qty: 4, price: 120 }
        ],
        status: "pending"
      }
    ];

    // Load from local storage
    function loadInvoices() {
      const stored = localStorage.getItem('parchilo_invoices');
      if (stored) {
        invoices = JSON.parse(stored);
      } else {
        invoices = [...mockInvoices];
        saveInvoices();
      }
      renderInvoices();
    }

    // Save to local storage
    function saveInvoices() {
      localStorage.setItem('parchilo_invoices', JSON.stringify(invoices));
    }

    // Nav shadow on scroll
    window.addEventListener('scroll', () => {
      document.getElementById('mainNav').classList.toggle('scrolled', window.scrollY > 20);
    });

    // Mobile Hamburger
    const hamburger = document.getElementById('hamburger');
    const mobileMenu = document.getElementById('mobileMenu');

    hamburger.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = mobileMenu.classList.toggle('open');
      hamburger.classList.toggle('open', isOpen);
    });

    mobileMenu.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', () => {
        mobileMenu.classList.remove('open');
        hamburger.classList.remove('open');
      });
    });

    document.addEventListener('click', (e) => {
      if (!hamburger.contains(e.target) && !mobileMenu.contains(e.target)) {
        mobileMenu.classList.remove('open');
        hamburger.classList.remove('open');
      }
    });



    function formatCurrency(amount, currency) {
      if (currency === '$' || currency === '€') {
        return currency + amount.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
      }
      return currency + amount.toLocaleString(undefined, { maximumFractionDigits: 0 });
    }



    // Drag and Drop File Handling (Mock parsing)
    const dropZone = document.getElementById('dropZone');
    const fileInput = document.getElementById('fileInput');

    dropZone.addEventListener('click', () => fileInput.click());

    dropZone.addEventListener('dragover', (e) => {
      e.preventDefault();
      dropZone.classList.add('dragover');
    });

    dropZone.addEventListener('dragleave', () => {
      dropZone.classList.remove('dragover');
    });

    dropZone.addEventListener('drop', (e) => {
      e.preventDefault();
      dropZone.classList.remove('dragover');
      const files = e.dataTransfer.files;
      if (files.length > 0) {
        simulateInvoiceParsing(files[0].name);
      }
    });

    fileInput.addEventListener('change', (e) => {
      if (e.target.files.length > 0) {
        simulateInvoiceParsing(e.target.files[0].name);
      }
    });

    function simulateInvoiceParsing(fileName) {
      // Show loader panel, hide drop zone
      dropZone.style.display = 'none';
      const loader = document.getElementById('parsingLoader');
      loader.style.display = 'flex';

      // Reset steps classes
      const steps = [
        document.getElementById('step1'),
        document.getElementById('step2'),
        document.getElementById('step3'),
        document.getElementById('step4')
      ];

      steps.forEach(step => {
        step.className = 'parsing-step';
        step.querySelector('i').className = '';
        step.querySelector('i').setAttribute('data-lucide', 'circle');
      });
      lucide.createIcons();

      // Step 1
      setTimeout(() => {
        steps[0].className = 'parsing-step active';
        steps[0].querySelector('i').className = 'spinner';
        steps[0].querySelector('i').setAttribute('data-lucide', 'loader');
        lucide.createIcons();
      }, 0);

      // Step 2
      setTimeout(() => {
        steps[0].className = 'parsing-step done';
        steps[0].querySelector('i').className = '';
        steps[0].querySelector('i').setAttribute('data-lucide', 'check-circle');
        
        steps[1].className = 'parsing-step active';
        steps[1].querySelector('i').className = 'spinner';
        steps[1].querySelector('i').setAttribute('data-lucide', 'loader');
        lucide.createIcons();
      }, 1000);

      // Step 3
      setTimeout(() => {
        steps[1].className = 'parsing-step done';
        steps[1].querySelector('i').className = '';
        steps[1].querySelector('i').setAttribute('data-lucide', 'check-circle');
        
        steps[2].className = 'parsing-step active';
        steps[2].querySelector('i').className = 'spinner';
        steps[2].querySelector('i').setAttribute('data-lucide', 'loader');
        lucide.createIcons();
      }, 2000);

      // Step 4
      setTimeout(() => {
        steps[2].className = 'parsing-step done';
        steps[2].querySelector('i').className = '';
        steps[2].querySelector('i').setAttribute('data-lucide', 'check-circle');
        
        steps[3].className = 'parsing-step active';
        steps[3].querySelector('i').className = 'spinner';
        steps[3].querySelector('i').setAttribute('data-lucide', 'loader');
        lucide.createIcons();
      }, 3000);

      // Finish simulation
      setTimeout(() => {
        steps[3].className = 'parsing-step done';
        steps[3].querySelector('i').className = '';
        steps[3].querySelector('i').setAttribute('data-lucide', 'check-circle');
        lucide.createIcons();

        // Create mock extracted invoice based on filename
        let extClient = "UET Lahore Campus";
        let extEmail = "procurement@uet.edu.pk";
        let extInvNum = "INV-2026-" + Math.floor(100 + Math.random() * 900);
        let extItems = [
          { name: "Vite 5 Development Hosting Server License", qty: 2, price: 45000 },
          { name: "FBR GST Consultancy Service fee", qty: 1, price: 15000 }
        ];

        if (fileName.toLowerCase().includes('scanned') || fileName.toLowerCase().includes('pdf')) {
          extClient = "Standard Chartered Pakistan";
          extEmail = "finance@sc.com.pk";
          extItems = [
            { name: "Commercial Office Paper Packs A4", qty: 10, price: 1800 },
            { name: "Premium Network Router Linksys v2", qty: 1, price: 89000 },
            { name: "Installation & setup services", qty: 1, price: 12000 }
          ];
        }

        const newInv = {
          id: 'inv_' + Date.now(),
          invoiceNum: extInvNum,
          clientName: extClient,
          clientEmail: extEmail,
          date: new Date().toISOString().split('T')[0],
          currency: "₨",
          taxRate: 17,
          items: extItems,
          status: 'pending'
        };

        invoices.unshift(newInv);
        saveInvoices();

        // Show success, reset view
        showToast("Invoice auto-extracted successfully!");
        
        setTimeout(() => {
          loader.style.display = 'none';
          dropZone.style.display = 'flex';
          fileInput.value = '';
          
          // Open A4 preview modal
          viewA4Invoice(newInv.id);
        }, 1000);

      }, 4200);
    }

    // Ledger: Set Filter Status
    function setLedgerFilter(filter, element) {
      ledgerFilter = filter;
      
      const parent = element.parentElement;
      parent.querySelectorAll('.filter-btn').forEach(btn => btn.classList.remove('active'));
      element.classList.add('active');

      renderInvoices();
    }

    // Ledger: Search & filter invoices array
    function filterInvoices() {
      renderInvoices();
    }

    // Render Ledger Table (No-op since ledger section was removed)
    function renderInvoices() {
      return;
    }

    function toggleInvoiceStatus(id) {
      const idx = invoices.findIndex(i => i.id === id);
      if (idx !== -1) {
        invoices[idx].status = invoices[idx].status === 'paid' ? 'pending' : 'paid';
        saveInvoices();
        renderInvoices();
        showToast("Invoice status updated!");
      }
    }

    function deleteInvoice(id) {
      if (confirm("Are you sure you want to delete this invoice?")) {
        invoices = invoices.filter(i => i.id !== id);
        saveInvoices();
        renderInvoices();
        showToast("Invoice removed.");
      }
    }

    // Modal helpers
    function openModal(modalId, event) {
      if (event) event.preventDefault();
      document.getElementById(modalId).classList.add('open');
      document.body.style.overflow = 'hidden';
    }

    function closeModal(modalId) {
      document.getElementById(modalId).classList.remove('open');
      document.body.style.overflow = 'auto';
    }

    function closeModalOnOutsideClick(event, modalId) {
      if (event.target.id === modalId) {
        closeModal(modalId);
      }
    }

    // Generate A4 preview layout
    function viewA4Invoice(id) {
      const inv = invoices.find(i => i.id === id);
      if (!inv) return;

      const a4 = document.getElementById('a4Content');
      
      // Calculate subtotals
      let subtotal = 0;
      let itemsHtml = '';
      
      inv.items.forEach(item => {
        const itemTotal = item.qty * item.price;
        subtotal += itemTotal;
        itemsHtml += `
          <tr>
            <td>${escapeHtml(item.name)}</td>
            <td style="text-align: right;">${item.qty}</td>
            <td style="text-align: right;">${formatCurrency(item.price, inv.currency)}</td>
            <td style="text-align: right; font-weight: 700;">${formatCurrency(itemTotal, inv.currency)}</td>
          </tr>
        `;
      });

      const taxAmount = subtotal * (inv.taxRate / 100);
      const grandTotal = subtotal + taxAmount;

      a4.innerHTML = `
        <div class="a4-header">
          <div>
            <div class="a4-logo">PAR<span class="a4-logo-invert">CHI</span>LO</div>
            <p style="margin-top: 4px; font-weight: 500; font-size: 11px; color: var(--dim)">Nexaura Technologies Partner</p>
          </div>
          <div class="a4-meta-col">
            <div class="a4-meta-title">Invoice</div>
            <p style="color: var(--dim); font-size: 11px;">Processed locally</p>
          </div>
        </div>

        <div class="a4-bill-row">
          <div class="a4-bill-col">
            <h5>Billed From</h5>
            <strong>Parchilo Services Ltd</strong>
            <p style="margin-top: 4px; font-size: 11px; color: var(--muted);">
              Plot 45, Sector I-10/3<br>
              Islamabad, Pakistan<br>
              GST: GST-9988112-2<br>
              NTN: 8877112-0
            </p>
          </div>
          <div class="a4-bill-col">
            <h5>Billed To</h5>
            <strong>${escapeHtml(inv.clientName)}</strong>
            <p style="margin-top: 4px; font-size: 11px; color: var(--muted);">
              ${escapeHtml(inv.clientEmail || 'No Billing Email')}<br>
              Islamabad, Pakistan
            </p>
          </div>
        </div>

        <div class="a4-bill-row" style="margin-bottom: 32px;">
          <div class="a4-bill-col">
            <h5>Invoice Metadata</h5>
            <div class="a4-meta-grid">
              <label>Invoice Number:</label> <span>${escapeHtml(inv.invoiceNum)}</span>
              <label>Issue Date:</label> <span>${inv.date}</span>
              <label>Payment Terms:</label> <span>Due on Receipt</span>
            </div>
          </div>
          <div class="a4-bill-col">
            <h5>Status</h5>
            <span style="font-weight: 900; text-transform: uppercase; font-size: 14px; color: ${inv.status === 'paid' ? 'var(--green)' : 'var(--amber)'}">
              ${inv.status}
            </span>
          </div>
        </div>

        <table class="a4-table">
          <thead>
            <tr>
              <th style="width: 50%;">Description</th>
              <th style="width: 10%; text-align: right;">Qty</th>
              <th style="width: 20%; text-align: right;">Unit Price</th>
              <th style="width: 20%; text-align: right;">Amount</th>
            </tr>
          </thead>
          <tbody>
            ${itemsHtml}
          </tbody>
        </table>

        <div class="a4-total-grid">
          <label>Subtotal:</label> <span>${formatCurrency(subtotal, inv.currency)}</span>
          <label>Tax Rate (${inv.taxRate}%):</label> <span>${formatCurrency(taxAmount, inv.currency)}</span>
          <label class="grand-total-label">Grand Total:</label> <span class="grand-total-val">${formatCurrency(grandTotal, inv.currency)}</span>
        </div>

        <div class="a4-footer">
          <p>Thank you for your business. For invoice questions, please contact billing@parchilo.com</p>
          <p style="margin-top: 6px; font-size: 9px; color: var(--xdim);">Generated by Parchilo Invoice System. Secure client-side ledger.</p>
        </div>
      `;

      openModal('invoicePreviewModal');
    }

    function printInvoice() {
      window.print();
    }

    // Helper for toast popup message
    let toastTimeout;
    function showToast(message) {
      const toast = document.getElementById('toastMessage');
      const text = document.getElementById('toastText');

      text.innerText = message;
      toast.classList.add('show');

      clearTimeout(toastTimeout);
      toastTimeout = setTimeout(() => {
        toast.classList.remove('show');
      }, 3000);
    }

    // HTML escape helper
    function escapeHtml(string) {
      const map = {
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&#039;'
      };
      return String(string).replace(/[&<>"']/g, function(m) { return map[m]; });
    }

    // Document setup on page load
    document.addEventListener("DOMContentLoaded", () => {
      loadInvoices();
    });
  </script>
</body>

</html>
