<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CMS Admin Panel — Parchilo</title>
  <link rel="icon" type="image/x-icon" href="favicon.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap"
    rel="stylesheet">
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
  <script src="config.js"></script>
  <script src="https://unpkg.com/@supabase/supabase-js@2"></script>
  <style>
    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    :root {
      --white: #ffffff;
      --bg: #f4f5f7;
      --border: #e2e8f0;
      --border-dark: #2d3748;
      --black: #0a0a0a;
      --blue: #2563eb;
      --blue-lt: #eff6ff;
      --lime: #c8f135;
      --lime-dark: #a8d020;
      --green: #10b981;
      --green-lt: #ecfdf5;
      --amber: #f59e0b;
      --amber-lt: #fef3c7;
      --muted: #4a5568;
      --dim: #718096;
      --xdim: #a0aec0;
      --shadow-sm: 0 1px 3px rgba(10, 10, 10, .05);
      --shadow: 0 4px 16px rgba(10, 10, 10, .06);
      --shadow-md: 0 8px 24px rgba(10, 10, 10, .08);
      --shadow-lg: 0 20px 48px rgba(10, 10, 10, .1);
      --shadow-nav: 0 2px 20px rgba(10, 10, 10, .08);
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      background: var(--bg);
      color: var(--black);
      font-family: 'Inter', sans-serif;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    /* ═══════ NAV ═══════ */
    .nav-wrap {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 900;
      padding: 8px 4vw;
      pointer-events: none;
    }

    nav {
      max-width: 500px;
      margin: 0 auto;
      height: 46px;
      background: rgba(255, 255, 255, 0.85);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-radius: 100px;
      border: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 6px 0 16px;
      box-shadow: var(--shadow-nav);
      pointer-events: all;
      transition: all .3s ease;
    }

    nav.scrolled {
      background: rgba(255, 255, 255, 0.95);
      box-shadow: 0 4px 30px rgba(10, 10, 10, .12);
    }

    .nav-logo {
      display: flex;
      align-items: center;
      text-decoration: none;
      flex-shrink: 0;
    }

    .logo-wordmark {
      font-size: 16.5px;
      font-weight: 900;
      color: var(--black);
      letter-spacing: -.04em;
      text-transform: uppercase;
      display: flex;
      align-items: center;
    }

    .logo-invert {
      background: var(--black);
      color: var(--white);
      padding: 1px 4px;
      border-radius: 4px;
      margin: 0 1px;
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 2px;
      list-style: none;
      background: rgba(0, 0, 0, 0.04);
      border-radius: 100px;
      padding: 3px;
    }

    .nav-links li a {
      display: flex;
      align-items: center;
      gap: 6px;
      text-decoration: none;
      font-size: 12.5px;
      font-weight: 600;
      color: var(--muted);
      padding: 5px 12px;
      border-radius: 100px;
      transition: all .15s;
      white-space: nowrap;
    }

    .nav-links li a:hover,
    .nav-links li a.active {
      background: var(--white);
      color: var(--black);
      box-shadow: var(--shadow-sm);
    }

    .nav-hamburger {
      display: none;
      flex-direction: column;
      gap: 5px;
      background: none;
      border: none;
      cursor: pointer;
      padding: 8px;
      flex-shrink: 0;
    }

    .nav-hamburger span {
      display: block;
      width: 20px;
      height: 2px;
      background: var(--black);
      border-radius: 2px;
      transition: all .25s;
    }

    /* Mobile menu */
    .mobile-menu {
      display: none;
      position: fixed;
      top: 66px;
      left: 4vw;
      right: 4vw;
      z-index: 800;
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 16px;
      box-shadow: var(--shadow-lg);
      flex-direction: column;
      gap: 4px;
    }

    .mobile-menu.open {
      display: flex;
    }

    .mobile-menu a {
      display: flex;
      align-items: center;
      gap: 10px;
      text-decoration: none;
      font-size: 15px;
      font-weight: 600;
      color: var(--muted);
      padding: 12px 14px;
      border-radius: 12px;
      transition: all .15s;
    }

    .mobile-menu a:hover {
      background: var(--bg);
      color: var(--black);
    }

    @media (max-width: 640px) {
      .nav-links {
        display: none;
      }

      .nav-hamburger {
        display: flex;
      }
    }

    /* ═══════ HEADER ═══════ */
    .admin-hero {
      padding: 100px 4vw 36px;
      text-align: center;
      background: linear-gradient(180deg, rgba(239, 246, 255, 0.8) 0%, rgba(244, 245, 247, 0) 100%);
    }

    .admin-hero h1 {
      font-size: clamp(28px, 4vw, 42px);
      font-weight: 900;
      letter-spacing: -.03em;
      color: var(--black);
      margin-bottom: 8px;
    }

    .admin-hero p {
      font-size: 15px;
      color: var(--muted);
      max-width: 600px;
      margin: 0 auto;
    }

    .db-status-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 100px;
      padding: 4px 12px;
      font-size: 12px;
      font-weight: 600;
      margin-top: 14px;
      box-shadow: var(--shadow-sm);
    }

    .status-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--amber);
    }

    .status-dot.active {
      background: var(--green);
    }

    /* ═══════ MAIN CONTENT GRID ═══════ */
    .admin-container {
      max-width: 1200px;
      margin: 0 auto 80px;
      padding: 0 4vw;
      display: grid;
      grid-template-columns: 1.2fr 0.8fr;
      gap: 32px;
    }

    @media (max-width: 900px) {
      .admin-container {
        grid-template-columns: 1fr;
      }
    }

    /* ═══════ DARK PANEL / COMPOSER FORM ═══════ */
    .composer-card {
      background: #0f172a;
      border: 1px solid #1e293b;
      border-radius: 24px;
      padding: 32px;
      color: var(--white);
      box-shadow: var(--shadow-lg);
    }

    .composer-title {
      font-size: 20px;
      font-weight: 800;
      margin-bottom: 24px;
      border-bottom: 1px solid #1e293b;
      padding-bottom: 16px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .form-group {
      margin-bottom: 20px;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }

    @media (max-width: 600px) {
      .form-row {
        grid-template-columns: 1fr;
      }
    }

    label {
      font-size: 12px;
      font-weight: 700;
      color: #94a3b8;
      text-transform: uppercase;
      letter-spacing: .05em;
    }

    input,
    select,
    textarea {
      width: 100%;
      background: #1e293b;
      border: 1px solid #334155;
      border-radius: 8px;
      padding: 10px 14px;
      color: var(--white);
      font-family: 'Inter', sans-serif;
      font-size: 13.5px;
      outline: none;
      transition: all .2s;
    }

    input:focus,
    select:focus,
    textarea:focus {
      border-color: var(--lime);
      box-shadow: 0 0 0 2px rgba(200, 241, 53, 0.15);
    }

    textarea {
      resize: vertical;
      min-height: 120px;
    }

    .rich-textarea {
      min-height: 240px;
      font-family: 'Courier New', Courier, monospace;
    }

    .theme-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 10px;
    }

    .theme-radio {
      position: relative;
      cursor: pointer;
    }

    .theme-radio input {
      position: absolute;
      opacity: 0;
      cursor: pointer;
      height: 0;
      width: 0;
    }

    .theme-box {
      border: 1px solid #334155;
      border-radius: 8px;
      padding: 10px;
      text-align: center;
      font-size: 11px;
      font-weight: 700;
      background: #1e293b;
      transition: all .15s;
    }

    .theme-radio input:checked~.theme-box {
      border-color: var(--lime);
      background: #334155;
      color: var(--lime);
    }

    .btn-submit {
      width: 100%;
      background: var(--lime);
      color: var(--black);
      border: none;
      border-radius: 8px;
      padding: 12px;
      font-size: 14px;
      font-weight: 800;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      margin-top: 10px;
      transition: all .15s;
    }

    .btn-submit:hover {
      background: var(--lime-dark);
      transform: translateY(-1px);
    }

    /* ═══════ LIGHT DASHBOARD CARD ═══════ */
    .dashboard-card {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 24px;
      padding: 32px;
      box-shadow: var(--shadow);
    }

    .dash-title {
      font-size: 20px;
      font-weight: 800;
      color: var(--black);
      margin-bottom: 24px;
      border-bottom: 1px solid var(--border);
      padding-bottom: 16px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .blog-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px 0;
      border-bottom: 1px dashed var(--border);
      gap: 16px;
    }

    .blog-item:last-child {
      border-bottom: none;
    }

    .blog-meta-info {
      display: flex;
      flex-direction: column;
    }

    .blog-item-title {
      font-size: 13.5px;
      font-weight: 700;
      color: var(--black);
      line-height: 1.4;
    }

    .blog-item-sub {
      font-size: 11.5px;
      color: var(--dim);
      margin-top: 4px;
      display: flex;
      gap: 12px;
    }

    .item-actions {
      display: flex;
      gap: 8px;
    }

    .btn-icon {
      background: none;
      border: 1px solid var(--border);
      border-radius: 6px;
      width: 28px;
      height: 28px;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      color: var(--muted);
      transition: all .15s;
    }

    .btn-icon:hover {
      background: var(--bg);
      color: var(--black);
    }

    .btn-icon.delete:hover {
      border-color: #f87171;
      color: #ef4444;
      background: #fef2f2;
    }

    .no-blogs-prompt {
      text-align: center;
      padding: 32px 0;
      color: var(--dim);
      font-size: 13px;
    }

    .btn-reset {
      background: none;
      border: 1px solid var(--border);
      border-radius: 8px;
      color: var(--muted);
      font-size: 12.5px;
      font-weight: 600;
      padding: 8px 16px;
      cursor: pointer;
      margin-top: 20px;
      width: 100%;
      transition: all .15s;
    }

    .btn-reset:hover {
      background: var(--bg);
      color: var(--black);
    }

    /* Toast */
    .toast {
      position: fixed;
      bottom: 24px;
      left: 50%;
      transform: translateX(-50%) translateY(100px);
      background: var(--black);
      color: var(--white);
      padding: 12px 24px;
      border-radius: 100px;
      font-size: 13px;
      font-weight: 600;
      box-shadow: var(--shadow-lg);
      display: flex;
      align-items: center;
      gap: 8px;
      z-index: 1000;
      opacity: 0;
      transition: all .4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .toast.show {
      transform: translateX(-50%) translateY(0);
      opacity: 1;
    }

    /* ═══════ FOOTER ═══════ */
    footer {
      background: var(--white);
      border-top: 1px solid var(--border);
      padding: 48px 4vw 24px;
    }

    footer .fg {
      max-width: 1340px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 2fr 1fr 1fr;
      gap: 32px;
      margin-bottom: 24px;
    }

    @media (max-width: 768px) {
      footer .fg {
        grid-template-columns: 1fr;
        gap: 24px;
      }
    }

    .fd {
      font-size: 12.5px;
      color: var(--dim);
      margin-top: 11px;
      line-height: 1.7;
      max-width: 280px;
    }

    .fct {
      font-size: 11.5px;
      font-weight: 700;
      color: var(--black);
      margin-bottom: 11px;
    }

    .fl {
      list-style: none;
    }

    .fl li {
      margin-bottom: 7px;
    }

    .fl a {
      text-decoration: none;
      font-size: 12.5px;
      color: var(--dim);
      transition: color .15s;
    }

    .fl a:hover {
      color: var(--black);
    }

    .fb {
      max-width: 1340px;
      margin: 36px auto 0;
      padding-top: 16px;
      border-top: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 10px;
    }

    .fbc {
      font-size: 12.5px;
      color: var(--dim);
    }

    .fbr {
      display: flex;
      gap: 8px;
    }

    .fchip {
      background: var(--bg);
      border: 1px solid var(--border);
      font-size: 10px;
      font-weight: 700;
      padding: 2px 8px;
      border-radius: 4px;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: .02em;
    }
  </style>
</head>

<body>

  <!-- ══ NAV ══ -->
  <div class="nav-wrap">
    <nav id="mainNav">
      <a href="index.html" class="nav-logo">
        <span class="logo-wordmark">
          <span>PAR</span><span class="logo-invert">CHI</span><span>LO</span>
        </span>
      </a>

      <ul class="nav-links">
        <li><a href="index.html"><i data-lucide="home" style="width:13px;height:13px"></i> Home</a></li>
        <li><a href="blogs.html"><i data-lucide="book-open" style="width:13px;height:13px"></i> Blogs</a></li>
        <li><a href="contact.html"><i data-lucide="mail" style="width:13px;height:13px"></i> Contact Us</a></li>
      </ul>

      <button class="nav-hamburger" id="hamburger" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </nav>
  </div>

  <!-- Mobile menu -->
  <div class="mobile-menu" id="mobileMenu">
    <a href="index.html"><i data-lucide="home" style="width:16px;height:16px"></i> Home</a>
    <a href="blogs.html"><i data-lucide="book-open" style="width:16px;height:16px"></i> Blogs</a>
    <a href="contact.html"><i data-lucide="mail" style="width:16px;height:16px"></i> Contact Us</a>
  </div>

  <!-- ══ HERO ══ -->
  <header class="admin-hero">
    <h1>Blog Manager CMS</h1>
    <p>Compose and publish dynamic articles instantly. Write raw HTML or markdown content, style abstract geometric SVG
      covers, and sync with your database.</p>

    <div class="db-status-badge">
      <div class="status-dot" id="dbStatusDot"></div>
      <span id="dbStatusText">Offline Mode (LocalStorage)</span>
    </div>
  </header>

  <!-- ══ MAIN LAYOUT ══ -->
  <main class="admin-container">

    <!-- Left Column: Composer Form -->
    <section class="composer-card">
      <h2 class="composer-title" id="formTitle">
        <span>Create Blog Post</span>
        <button type="button" class="btn-reset" style="margin: 0; width: auto; padding: 4px 12px; font-size: 11px;"
          onclick="resetForm()">Cancel Edit</button>
      </h2>

      <form id="composerForm" onsubmit="handleFormSubmit(event)">
        <input type="hidden" id="editPostId" value="">

        <div class="form-group">
          <label for="postTitle">Article Title</label>
          <input type="text" id="postTitle" required placeholder="e.g. Scaling Real-Time Webhooks with Redis Streams">
        </div>

        <div class="form-group">
          <label for="postExcerpt">Brief Excerpt</label>
          <input type="text" id="postExcerpt" required
            placeholder="A short summary of the article displayed on the listing cards...">
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="postCategory">Category</label>
            <select id="postCategory">
              <option value="AI & Technology">AI &amp; Tech</option>
              <option value="Development">Development</option>
              <option value="Design & UX">Design &amp; UX</option>
              <option value="Workflows">Workflows</option>
            </select>
          </div>

          <div class="form-group">
            <label for="postReadTime">Estimated Read Time</label>
            <input type="text" id="postReadTime" required placeholder="e.g. 5 min read">
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="postAuthor">Author Name</label>
            <input type="text" id="postAuthor" required placeholder="e.g. Anya Lopez">
          </div>

          <div class="form-group">
            <label for="postDate">Publish Date</label>
            <input type="text" id="postDate" required placeholder="e.g. July 8, 2026">
          </div>
        </div>

        <!-- Abstract SVG Cover Theme Selector -->
        <div class="form-group">
          <label>Cover Visual Theme</label>
          <div class="theme-grid">
            <label class="theme-radio">
              <input type="radio" name="coverTheme" value="cyber" checked>
              <div class="theme-box" style="background: #0b1120; color: #c8f135;">AI Cyber</div>
            </label>
            <label class="theme-radio">
              <input type="radio" name="coverTheme" value="storage">
              <div class="theme-box" style="background: #131b2e; color: #3b82f6;">Database</div>
            </label>
            <label class="theme-radio">
              <input type="radio" name="coverTheme" value="ux">
              <div class="theme-box" style="background: #1a102f; color: #ec4899;">Design UX</div>
            </label>
            <label class="theme-radio">
              <input type="radio" name="coverTheme" value="fiscal">
              <div class="theme-box" style="background: #091e16; color: #10b981;">Teal Flow</div>
            </label>
          </div>
        </div>

        <div class="form-group">
          <label for="postBody">HTML / Content Body</label>
          <textarea id="postBody" class="rich-textarea" required
            placeholder="Write your full article body in HTML (use <p>, <h2>, <blockquote>, <pre><code> for formatting)..."></textarea>
        </div>

        <button type="submit" class="btn-submit" id="submitBtn">
          <i data-lucide="send" style="width: 16px; height: 16px;"></i> Publish Article
        </button>
      </form>
    </section>

    <!-- Right Column: Listing Dashboard -->
    <section class="dashboard-card">
      <h2 class="dash-title">Published Articles</h2>

      <div id="articlesList">
        <!-- Injected dynamically -->
      </div>

      <button class="btn-reset" onclick="triggerSeedReset()"><i data-lucide="refresh-cw"
          style="width:12px; height:12px; display:inline-block; vertical-align:middle; margin-right:4px;"></i> Reset to
        Seed Articles</button>
    </section>

  </main>

  <!-- Toast -->
  <div class="toast" id="toastMessage">
    <i data-lucide="check-circle" style="width: 16px; height: 16px;"></i>
    <span id="toastText">Article Published!</span>
  </div>

  <!-- ══ FOOTER ══ -->
  <footer>
    <div class="fg">
      <div>
        <span class="logo-wordmark" style="font-size:16px">
          <span>PAR</span><span class="logo-invert">CHI</span><span>LO</span>
        </span>
        <p class="fd">
          Premium development blog and engineering insights platform, powered by Nexaura Technologies.
        </p>
      </div>
      <div>
        <div class="fct">Navigation</div>
        <ul class="fl">
          <li><a href="index.html">Home</a></li>
          <li><a href="blogs.html">Blogs</a></li>
          <li><a href="contact.html">Contact Us</a></li>
        </ul>
      </div>
      <div>
        <div class="fct">Legal Documents</div>
        <ul class="fl">
          <li><a href="terms.html">Terms &amp; Conditions</a></li>
          <li><a href="privacy.html">Privacy Policy</a></li>
        </ul>
      </div>
    </div>
    <div class="fb">
      <div class="fbc">© 2026 <span>Parchilo</span>. All rights reserved. Built by Nexaura.</div>
      <div class="fbr">
        <span class="fchip">SSL Secured</span>
        <span class="fchip">v4.0 (Admin Hub)</span>
      </div>
    </div>
  </footer>

  <script>
    // Initialize icons
    lucide.createIcons();

    // Nav shadow on scroll
    window.addEventListener('scroll', () => {
      document.getElementById('mainNav').classList.toggle('scrolled', window.scrollY > 20);
    });

    // Mobile Hamburger
    const hamburger = document.getElementById('hamburger');
    const mobileMenu = document.getElementById('mobileMenu');
    hamburger.addEventListener('click', () => {
      mobileMenu.classList.toggle('open');
    });

    // Initialize Supabase Client
    let supabaseClient = null;
    if (typeof supabase !== 'undefined' && SUPABASE_URL && SUPABASE_ANON_KEY) {
      try {
        supabaseClient = supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);
        document.getElementById('dbStatusDot').classList.add('active');
        document.getElementById('dbStatusText').innerText = "Connected to Supabase DB";
      } catch (err) {
        console.error("Supabase client init failed:", err);
      }
    }

    // Default Seed posts matching blogs.html
    const defaultSeedPosts = [
      {
        id: "ai-trends",
        title: "The Evolution of Client-Side AI in Modern Web Applications",
        category: "AI & Technology",
        date: "July 8, 2026",
        readTime: "6 min read",
        author: "Sarah Jenkins",
        avatar: "SJ",
        avatarBg: "#c8f135",
        avatarColor: "#0a0a0a",
        excerpt: "Explore how running machine learning models locally on the browser is transforming UX, reducing server latency, and ensuring absolute user data privacy.",
        svg: `<svg width="100%" height="100%" viewBox="0 0 350 200" fill="none" xmlns="http://www.w3.org/2000/svg" style="background:#0b1120;">
                <circle cx="175" cy="100" r="50" stroke="#c8f135" stroke-width="1" stroke-dasharray="3 6" opacity="0.3"/>
                <circle cx="175" cy="100" r="20" fill="#c8f135" opacity="0.8"/>
                <path d="M40 30 L310 170" stroke="#c8f135" stroke-width="1" opacity="0.15"/>
              </svg>`,
        body: `
          <p>For years, running complex machine learning tasks meant sending user data back to hefty GPU servers, incurring latency penalties, high infrastructure costs, and data leakage concerns. Today, a paradigm shift is underway. Running inference directly inside the browser sandbox is finally practical.</p>
          <h2>Why Client-Side AI?</h2>
          <p>Local execution solves three core bottlenecks: latency, bandwidth cost, and privacy. When code runs client-side, it eliminates the roundtrip to a remote server. Interactions become instantaneous, unlocking fluid UI flows like real-time text analysis or live object detection on high-refresh-rate webcams.</p>
          <blockquote>"By executing machine learning models directly on the client, web apps can operate fully offline while maintaining absolute compliance with privacy acts like GDPR and HIPAA."</blockquote>
          <h2>Technological Pillars: WASM, WebGPU &amp; WebGL</h2>
          <p>This revolution is fueled by browser hardware acceleration. WebAssembly (Wasm) provides near-native execution speed for traditional CPU operations. Simultaneously, WebGL and the new WebGPU standard allow Javascript to tap directly into client graphics hardware, enabling highly parallelized tensor calculations.</p>
        `
      },
      {
        id: "local-storage",
        title: "Leveraging Local Browser Storage for Offline Web Apps",
        category: "Development",
        date: "July 7, 2026",
        readTime: "5 min read",
        author: "Marcus Evans",
        avatar: "ME",
        avatarBg: "#2563eb",
        avatarColor: "#ffffff",
        excerpt: "Learn best practices for structuring client-side offline stores using IndexedDB, cache parameters, and offline-first state syncing.",
        svg: `<svg width="100%" height="100%" viewBox="0 0 350 200" fill="none" xmlns="http://www.w3.org/2000/svg" style="background:#131b2e;">
                <rect x="40" y="40" width="270" height="120" rx="8" stroke="#334155" stroke-width="2"/>
                <line x1="40" y1="70" x2="310" y2="70" stroke="#334155" stroke-width="2"/>
                <circle cx="75" cy="55" r="4" fill="#f59e0b"/>
                <circle cx="90" cy="55" r="4" fill="#10b981"/>
                <path d="M80 100 L120 140 M120 100 L80 140" stroke="#c8f135" stroke-width="3" stroke-linecap="round" opacity="0.8"/>
              </svg>`,
        body: `
          <p>Modern applications are expected to work under any network condition. If a user enters a tunnel or boards a plane, the application should not freeze. Designing for offline-first is no longer a luxury; it is a core feature of engineering solid web solutions.</p>
          <h2>The Hierarchy of Browser Storage</h2>
          <p>To store state locally, browsers provide several storage vectors. Knowing when to use what is crucial:</p>
          <ul>
            <li><strong>LocalStorage:</strong> Synchronous, string-only key-value storage. Best used for light preference settings (like UI theme modes) under 5MB.</li>
            <li><strong>IndexedDB:</strong> Asynchronous, transactional object-store database. Excellent for handling large structured records, indices, and blob media binary files.</li>
          </ul>
        `
      }
    ];

    let currentBlogs = [];

    // Set default date in form input
    document.getElementById('postDate').value = new Date().toLocaleDateString('en-US', {
      month: 'long',
      day: 'numeric',
      year: 'numeric'
    });

    // Helper: generate abstract SVG based on theme selection
    function generateSVGForTheme(theme) {
      if (theme === 'cyber') {
        return `<svg width="100%" height="100%" viewBox="0 0 350 200" fill="none" xmlns="http://www.w3.org/2000/svg" style="background:#0b1120;">
                <circle cx="175" cy="100" r="50" stroke="#c8f135" stroke-width="1" stroke-dasharray="3 6" opacity="0.3"/>
                <circle cx="175" cy="100" r="20" fill="#c8f135" opacity="0.8"/>
                <path d="M40 30 L310 170" stroke="#c8f135" stroke-width="1" opacity="0.15"/>
              </svg>`;
      } else if (theme === 'storage') {
        return `<svg width="100%" height="100%" viewBox="0 0 350 200" fill="none" xmlns="http://www.w3.org/2000/svg" style="background:#131b2e;">
                <rect x="40" y="40" width="270" height="120" rx="8" stroke="#334155" stroke-width="2"/>
                <line x1="40" y1="70" x2="310" y2="70" stroke="#334155" stroke-width="2"/>
                <circle cx="75" cy="55" r="4" fill="#f59e0b"/>
                <circle cx="90" cy="55" r="4" fill="#10b981"/>
              </svg>`;
      } else if (theme === 'ux') {
        return `<svg width="100%" height="100%" viewBox="0 0 350 200" fill="none" xmlns="http://www.w3.org/2000/svg" style="background:#1a102f;">
                <path d="M50 150 Q100 50, 150 120 T250 80 T300 150" stroke="#c8f135" stroke-width="3" fill="none" stroke-linecap="round"/>
                <circle cx="150" cy="120" r="6" fill="#2563eb"/>
                <circle cx="250" cy="80" r="6" fill="#10b981"/>
              </svg>`;
      } else {
        return `<svg width="100%" height="100%" viewBox="0 0 350 200" fill="none" xmlns="http://www.w3.org/2000/svg" style="background:#091e16;">
                <rect x="60" y="40" width="230" height="120" rx="6" stroke="#10b981" stroke-width="2" fill="none"/>
                <path d="M90 70 H260 M90 100 H260 M90 130 H180" stroke="#334155" stroke-width="2" stroke-linecap="round"/>
                <circle cx="240" cy="130" r="15" fill="#c8f135"/>
              </svg>`;
      }
    }

    // Helper: generate avatar colors based on author initials
    function getAuthorDesign(author) {
      const initials = author.split(' ').map(n => n[0]).join('').toUpperCase().slice(0, 2);
      const bgColors = ["#2563eb", "#10b981", "#ec4899", "#c8f135", "#f59e0b", "#8b5cf6"];
      const charSum = initials.charCodeAt(0) + (initials.charCodeAt(1) || 0);
      const bg = bgColors[charSum % bgColors.length];
      const color = bg === "#c8f135" ? "#0a0a0a" : "#ffffff";
      return { initials, bg, color };
    }

    // Load blogs list
    async function loadBlogs() {
      // 1. Try Supabase
      if (supabaseClient) {
        try {
          const { data, error } = await supabaseClient
            .from('blogs')
            .select('*')
            .order('created_at', { ascending: false });

          if (error) throw error;
          if (data && data.length > 0) {
            currentBlogs = data.map(item => ({
              id: item.id,
              title: item.title,
              category: item.category,
              date: item.date,
              readTime: item.read_time,
              author: item.author,
              avatar: item.avatar,
              avatarBg: item.avatar_bg,
              avatarColor: item.avatar_color,
              excerpt: item.excerpt,
              svg: item.svg,
              body: item.body
            }));
            renderList();
            return;
          }
        } catch (err) {
          console.warn("Supabase fetch failed, falling back to local storage:", err);
        }
      }

      // 2. Fallback to LocalStorage
      const stored = localStorage.getItem('parchilo_blogs');
      if (stored) {
        currentBlogs = JSON.parse(stored);
      } else {
        currentBlogs = [...defaultSeedPosts];
        localStorage.setItem('parchilo_blogs', JSON.stringify(currentBlogs));
      }
      renderList();
    }

    // Render list of blogs
    function renderList() {
      const list = document.getElementById('articlesList');
      list.innerHTML = '';

      if (currentBlogs.length === 0) {
        list.innerHTML = `<div class="no-blogs-prompt">No published articles yet. Compose your first blog on the left!</div>`;
        return;
      }

      currentBlogs.forEach(blog => {
        const item = document.createElement('div');
        item.className = 'blog-item';
        item.innerHTML = `
          <div class="blog-meta-info">
            <span class="blog-item-title">${escapeHtml(blog.title)}</span>
            <div class="blog-item-sub">
              <span><strong>Category:</strong> ${blog.category}</span>
              <span><strong>Author:</strong> ${escapeHtml(blog.author)}</span>
              <span>${blog.date}</span>
            </div>
          </div>
          <div class="item-actions">
            <button class="btn-icon" onclick="editPost('${blog.id}')" title="Edit Article"><i data-lucide="edit-3" style="width:13px; height:13px"></i></button>
            <button class="btn-icon delete" onclick="deletePost('${blog.id}')" title="Delete Article"><i data-lucide="trash-2" style="width:13px; height:13px"></i></button>
          </div>
        `;
        list.appendChild(item);
      });

      lucide.createIcons();
    }

    // Handle Form Submit
    async function handleFormSubmit(e) {
      e.preventDefault();

      const editId = document.getElementById('editPostId').value;
      const title = document.getElementById('postTitle').value.trim();
      const excerpt = document.getElementById('postExcerpt').value.trim();
      const category = document.getElementById('postCategory').value;
      const readTime = document.getElementById('postReadTime').value.trim();
      const author = document.getElementById('postAuthor').value.trim();
      const date = document.getElementById('postDate').value.trim();
      const body = document.getElementById('postBody').value.trim();

      const themeRadio = document.querySelector('input[name="coverTheme"]:checked');
      const theme = themeRadio ? themeRadio.value : 'cyber';

      const id = editId ? editId : 'blog_' + Date.now();
      const svg = generateSVGForTheme(theme);
      const design = getAuthorDesign(author);

      const postData = {
        id,
        title,
        category,
        date,
        read_time: readTime,
        author,
        avatar: design.initials,
        avatar_bg: design.bg,
        avatar_color: design.color,
        excerpt,
        svg,
        body
      };

      // 1. Save to Supabase
      if (supabaseClient) {
        try {
          const { error } = await supabaseClient
            .from('blogs')
            .upsert([postData]);

          if (error) throw error;
          showToast("Article saved to Supabase successfully!");
        } catch (err) {
          console.error("Supabase upsert failed, saving offline:", err);
          saveLocal(postData);
        }
      } else {
        saveLocal(postData);
      }

      resetForm();
      loadBlogs();
    }

    // Save to localStorage helper
    function saveLocal(postData) {
      const idx = currentBlogs.findIndex(b => b.id === postData.id);

      // Adapt keys for localStorage compatibility
      const adapted = {
        id: postData.id,
        title: postData.title,
        category: postData.category,
        date: postData.date,
        readTime: postData.read_time,
        author: postData.author,
        avatar: postData.avatar,
        avatarBg: postData.avatar_bg,
        avatarColor: postData.avatar_color,
        excerpt: postData.excerpt,
        svg: postData.svg,
        body: postData.body
      };

      if (idx !== -1) {
        currentBlogs[idx] = adapted;
        showToast("Article updated locally.");
      } else {
        currentBlogs.unshift(adapted);
        showToast("Article published locally.");
      }
      localStorage.setItem('parchilo_blogs', JSON.stringify(currentBlogs));
    }

    // Edit Post loader
    function editPost(id) {
      const blog = currentBlogs.find(b => b.id === id);
      if (!blog) return;

      document.getElementById('editPostId').value = blog.id;
      document.getElementById('postTitle').value = blog.title;
      document.getElementById('postExcerpt').value = blog.excerpt;
      document.getElementById('postCategory').value = blog.category;
      document.getElementById('postReadTime').value = blog.readTime || blog.read_time;
      document.getElementById('postAuthor').value = blog.author;
      document.getElementById('postDate').value = blog.date;
      document.getElementById('postBody').value = blog.body;

      document.getElementById('formTitle').querySelector('span').innerText = "Edit Blog Post";
      document.getElementById('submitBtn').innerHTML = `<i data-lucide="check" style="width: 16px; height: 16px;"></i> Update Article`;
      lucide.createIcons();

      // Scroll to form
      document.querySelector('.composer-card').scrollIntoView({ behavior: 'smooth' });
    }

    // Delete Post
    async function deletePost(id) {
      if (!confirm("Are you sure you want to delete this article?")) return;

      // 1. Supabase delete
      if (supabaseClient) {
        try {
          const { error } = await supabaseClient
            .from('blogs')
            .delete()
            .eq('id', id);

          if (error) throw error;
          showToast("Article deleted from Supabase.");
        } catch (err) {
          console.error("Supabase delete failed, deleting locally:", err);
          deleteLocal(id);
        }
      } else {
        deleteLocal(id);
      }

      loadBlogs();
    }

    function deleteLocal(id) {
      currentBlogs = currentBlogs.filter(b => b.id !== id);
      localStorage.setItem('parchilo_blogs', JSON.stringify(currentBlogs));
      showToast("Article deleted locally.");
    }

    // Reset Form
    function resetForm() {
      document.getElementById('editPostId').value = "";
      document.getElementById('composerForm').reset();

      // Default date
      document.getElementById('postDate').value = new Date().toLocaleDateString('en-US', {
        month: 'long',
        day: 'numeric',
        year: 'numeric'
      });

      document.getElementById('formTitle').querySelector('span').innerText = "Create Blog Post";
      document.getElementById('submitBtn').innerHTML = `<i data-lucide="send" style="width: 16px; height: 16px;"></i> Publish Article`;
      lucide.createIcons();
    }

    // Seed Reset triggers
    async function triggerSeedReset() {
      if (!confirm("This will restore default seed posts. Continue?")) return;

      if (supabaseClient) {
        try {
          // Delete existing
          await supabaseClient.from('blogs').delete().neq('id', 'null');

          // Re-insert seeds
          const adaptedSeeds = defaultSeedPosts.map(item => ({
            id: item.id,
            title: item.title,
            category: item.category,
            date: item.date,
            read_time: item.readTime || item.read_time,
            author: item.author,
            avatar: item.avatar,
            avatar_bg: item.avatarBg || item.avatar_bg,
            avatar_color: item.avatarColor || item.avatar_color,
            excerpt: item.excerpt,
            svg: item.svg,
            body: item.body
          }));

          const { error } = await supabaseClient.from('blogs').insert(adaptedSeeds);
          if (error) throw error;
          showToast("Database seeded successfully!");
        } catch (err) {
          console.error("Supabase seeding failed, resetting locally:", err);
          resetLocalSeeds();
        }
      } else {
        resetLocalSeeds();
      }

      loadBlogs();
    }

    function resetLocalSeeds() {
      currentBlogs = [...defaultSeedPosts];
      localStorage.setItem('parchilo_blogs', JSON.stringify(currentBlogs));
      showToast("Local seed articles restored.");
    }

    // HTML escape helper
    function escapeHtml(string) {
      const map = {
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&#039;'
      };
      return String(string).replace(/[&<>"']/g, function (m) { return map[m]; });
    }

    // Toast popup helper
    let toastTimeout;
    function showToast(message) {
      const toast = document.getElementById('toastMessage');
      const text = document.getElementById('toastText');

      text.innerText = message;
      toast.classList.add('show');

      clearTimeout(toastTimeout);
      toastTimeout = setTimeout(() => {
        toast.classList.remove('show');
      }, 3000);
    }

    // Document setup
    document.addEventListener("DOMContentLoaded", () => {
      loadBlogs();
    });
  </script>
</body>

</html>